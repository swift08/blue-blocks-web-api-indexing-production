# Site URL used by sitemap generation (see scripts/generate-sitemap.js)
NEXT_PUBLIC_SITE_URL=https://www.blueblocks.in

# --- Google Indexing API (optional overrides) ---
# Default: uses ./indexing-service.json.json in the project root (gitignored).
# GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\other-key.json

# Alternative: paste the entire service account JSON as one line (CI / hosting secrets)
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Cap how many sitemap URLs to notify per run (Google has daily quotas)
# INDEX_GOOGLE_MAX_URLS=200

# Pause between requests in milliseconds
# INDEX_GOOGLE_DELAY_MS=150
