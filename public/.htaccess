# Section 8 - Blog wildcard (only fires for unknown blog URLs; real posts pass through)
RewriteCond %{HTTP_HOST} ^(www\.)?blueblocks\.in$ [NC]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^blog/.+$ https://blueblocks.in/blog/ [R=301,L,NE]

# Catch-all: any remaining .shtml URL not handled above -> homepage
RewriteCond %{HTTP_HOST} ^(www\.)?blueblocks\.in$ [NC]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^(.+)\.shtml$ https://blueblocks.in/ [R=301,L,NE]

# --------------------------------------------------
# 2) Canonical redirect for everything else
# --------------------------------------------------
RewriteCond %{HTTP_HOST} ^www\.blueblocks\.in$ [NC,OR]
RewriteCond %{HTTPS} !=on
RewriteRule ^(.*)$ https://blueblocks.in/$1 [R=301,L,NE]
