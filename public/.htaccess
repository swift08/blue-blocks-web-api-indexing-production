# Section 7 - Parents books
RewriteCond %{HTTP_HOST} ^(www\.)?blueblocks\.in$ [NC]
RewriteRule ^parents/books/maria-montessori/?$ https://blueblocks.in/parents/ [R=301,L,NE]

RewriteCond %{HTTP_HOST} ^(www\.)?blueblocks\.in$ [NC]
