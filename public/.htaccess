RewriteEngine On

# --------------------------------------------------
# 1) Old URLs -> final new URLs in ONE STEP
# --------------------------------------------------

# Main pages
RewriteCond %{HTTP_HOST} ^(www\.)?blueblocks\.in$ [NC]
RewriteRule ^about-us\.shtml/?$ https://blueblocks.in/about-us/ [R=301,L,NE]

RewriteCond %{HTTP_HOST} ^(www\.)?blueblocks\.in$ [NC]
RewriteRule ^montessori\.shtml/?$ https://blueblocks.in/montessori-system/ [R=301,L,NE]

RewriteCond %{HTTP_HOST} ^(www\.)?blueblocks\.in$ [NC]
RewriteRule ^careers\.shtml/?$ https://blueblocks.in/careers/ [R=301,L,NE]

RewriteCond %{HTTP_HOST} ^(www\.)?blueblocks\.in$ [NC]
RewriteRule ^campus\.shtml/?$ https://blueblocks.in/campus/ [R=301,L,NE]

RewriteCond %{HTTP_HOST} ^(www\.)?blueblocks\.in$ [NC]
RewriteRule ^faq\.shtml/?$ https://blueblocks.in/faq/ [R=301,L,NE]

RewriteCond %{HTTP_HOST} ^(www\.)?blueblocks\.in$ [NC]
RewriteRule ^admission\.shtml/?$ https://blueblocks.in/admissions/ [R=301,L,NE]

RewriteCond %{HTTP_HOST} ^(www\.)?blueblocks\.in$ [NC]
RewriteRule ^programs\.shtml/?$ https://blueblocks.in/programs/ [R=301,L,NE]

RewriteCond %{HTTP_HOST} ^(www\.)?blueblocks\.in$ [NC]
RewriteRule ^innovation\.shtml/?$ https://blueblocks.in/innovation/ [R=301,L,NE]

RewriteCond %{HTTP_HOST} ^(www\.)?blueblocks\.in$ [NC]
RewriteRule ^privacy-policy\.shtml/?$ https://blueblocks.in/privacy-policy/ [R=301,L,NE]

# Paper URL migration
RewriteCond %{HTTP_HOST} ^(www\.)?blueblocks\.in$ [NC]
RewriteRule ^toddler-developmental-architecture/?$ https://blueblocks.in/neuropsychiatry-of-toddler-plane/ [R=301,L,NE]

# Program pages
RewriteCond %{HTTP_HOST} ^(www\.)?blueblocks\.in$ [NC]
RewriteRule ^toddler\.shtml/?$ https://blueblocks.in/programs/playgroup/ [R=301,L,NE]

RewriteCond %{HTTP_HOST} ^(www\.)?blueblocks\.in$ [NC]
RewriteRule ^self\.shtml/?$ https://blueblocks.in/programs/nursery-school/ [R=301,L,NE]

RewriteCond %{HTTP_HOST} ^(www\.)?blueblocks\.in$ [NC]
RewriteRule ^elementary\.shtml/?$ https://blueblocks.in/programs/primary-school-elementary/ [R=301,L,NE]

RewriteCond %{HTTP_HOST} ^(www\.)?blueblocks\.in$ [NC]
RewriteRule ^high\.shtml/?$ https://blueblocks.in/programs/secondary-school/ [R=301,L,NE]

# Innovation pages
RewriteCond %{HTTP_HOST} ^(www\.)?blueblocks\.in$ [NC]
RewriteRule ^drone-patent\.shtml/?$ https://blueblocks.in/innovation/drone-lab/ [R=301,L,NE]

RewriteCond %{HTTP_HOST} ^(www\.)?blueblocks\.in$ [NC]
RewriteRule ^space-program\.shtml/?$ https://blueblocks.in/innovation/space-lab/ [R=301,L,NE]

RewriteCond %{HTTP_HOST} ^(www\.)?blueblocks\.in$ [NC]
RewriteRule ^biomimicryhive\.shtml/?$ https://blueblocks.in/innovation/biomimicry-hive/ [R=301,L,NE]

# Legacy/special
RewriteCond %{HTTP_HOST} ^(www\.)?blueblocks\.in$ [NC]
RewriteRule ^Innovation/CubeSat-Mission/?$ https://research.blueblocks.in/publications/CubeSat-INSPACE/ [R=301,L,NE]

# Resolved formerly unmapped items
RewriteCond %{HTTP_HOST} ^(www\.)?blueblocks\.in$ [NC]
RewriteRule ^positive-parenting\.shtml/?$ https://blueblocks.in/parents/ [R=301,L,NE]

RewriteCond %{HTTP_HOST} ^(www\.)?blueblocks\.in$ [NC]
RewriteRule ^virtual-learning\.shtml/?$ https://blueblocks.in/programs/ [R=301,L,NE]

RewriteCond %{HTTP_HOST} ^(www\.)?blueblocks\.in$ [NC]
RewriteRule ^public/resourses/documents/Drone-Innovation-and-Research\.pdf$ https://blueblocks.in/innovation/drone-lab/ [R=301,L,NE]

RewriteCond %{HTTP_HOST} ^(www\.)?blueblocks\.in$ [NC]
RewriteRule ^public/resources/documents/Drone-Innovation-and-Research\.pdf$ https://blueblocks.in/innovation/drone-lab/ [R=301,L,NE]

RewriteCond %{HTTP_HOST} ^(www\.)?blueblocks\.in$ [NC]
RewriteRule ^videos\.shtml/?$ https://blueblocks.in/videos/ [R=301,L,NE]

RewriteCond %{HTTP_HOST} ^(www\.)?blueblocks\.in$ [NC]
RewriteRule ^schedule-meeting-with-parent-coordinator\.shtml/?$ https://blueblocks.in/contact-us/ [R=301,L,NE]

RewriteCond %{HTTP_HOST} ^(www\.)?blueblocks\.in$ [NC]
RewriteRule ^schedule-meeting-with-director-elementory\.shtml/?$ https://blueblocks.in/admissions/ [R=301,L,NE]

# Homepage legacy
RewriteCond %{HTTP_HOST} ^(www\.)?blueblocks\.in$ [NC]
RewriteRule ^index\.(shtml|html?)$ https://blueblocks.in/ [R=301,L,NC,NE]

